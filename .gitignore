# Vendored SDK packages (debug branch only).
# Override the generic `dist` / `.papi/descriptors` rules so the
# prebuilt packages under vendor/truapi-debug/ ship to CI.
!vendor/truapi-debug/**/dist
!vendor/truapi-debug/**/dist/**
!vendor/truapi-debug/**/.papi
!vendor/truapi-debug/**/.papi/**
