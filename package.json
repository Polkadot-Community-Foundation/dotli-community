{
  "name": "dotli",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:perf": "PERF_RUNS=10 npx playwright test tests/cold-start.spec.ts",
    "test:perf:base": "PERF_RUNS=20 PERF_SAVE_BASE=1 npx playwright test tests/cold-start.spec.ts",
    "test:perf:headless": "HEADLESS=1 npx playwright test tests/cold-start.spec.ts",
    "test:perf:compare": "npx tsx tests/compare.ts",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "simple-statistics": "^7.8.8",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-wasm": "^3.5.0"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@ensdomains/content-hash": "^3.0.0",
    "@helia/unixfs": "^7.0.4",
    "@ipld/car": "^5.4.2",
    "@libp2p/websockets": "^10.1.5",
    "@multiformats/blake2": "^2.0.2",
    "@multiformats/multiaddr": "^13.0.1",
    "@noble/hashes": "^2.0.1",
    "@novasamatech/host-container": "^0.6.5",
    "@novasamatech/host-papp": "^0.6.5",
    "@novasamatech/statement-store": "^0.6.5",
    "@novasamatech/storage-adapter": "^0.6.5",
    "@scure/sr25519": "^1.0.0",
    "helia": "^6.0.20",
    "multiformats": "^13.4.2",
    "polkadot-api": "^1.23.3",
    "qrcode": "^1.5.4",
    "viem": "^2.46.3"
  },
  "trustedDependencies": [
    "node-datachannel"
  ]
}
