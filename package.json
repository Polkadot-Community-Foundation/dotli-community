{
  "name": "dotli",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/dotli.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "dev:host": "turbo run dev --filter=@dotli/host",
    "dev:sandbox": "turbo run dev --filter=@dotli/sandbox",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
