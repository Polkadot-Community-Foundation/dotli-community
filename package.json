{
  "name": "dotli",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "A decentralized web browser that runs in your browser.",
  "author": "Parity Technologies <admin@parity.io> (https://parity.io)",
  "homepage": "https://dot.li",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/dotli.git"
  },
  "bugs": {
    "url": "https://github.com/paritytech/dotli/issues"
  },
  "keywords": [
    "polkadot",
    "decentralized-web",
    "light-client",
    "smoldot",
    "dotns",
    "blockchain",
    "typescript",
    "vite"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "postinstall": "papi",
    "dev": "BUILD_TARGET=host bunx --bun vite",
    "dev:app": "BUILD_TARGET=app bunx --bun vite --port 5174",
    "build": "tsc && bun run build:host && bun run build:app && bun scripts/compress-dist.ts",
    "build:host": "BUILD_TARGET=host bunx --bun vite build",
    "build:app": "BUILD_TARGET=app bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "preview:test": "bun run build:host && bun run build:app && bun scripts/preview-server.ts",
    "test:perf": "PERF_RUNS=10 PERF_DOMAIN_A=hackme3 PERF_DOMAIN_B=insync bunx playwright test tests/cold-start.spec.ts",
    "test:perf:base": "PERF_RUNS=20 PERF_SAVE_BASE=1 PERF_DOMAIN_A=hackme3 PERF_DOMAIN_B=insync bunx playwright test tests/cold-start.spec.ts",
    "test:perf:headed": "HEADED=1 PERF_RUNS=10 PERF_DOMAIN_A=hackme3 PERF_DOMAIN_B=insync bunx playwright test tests/cold-start.spec.ts",
    "test:perf:compare": "bun tests/compare.ts",
    "test:perf:compare:verbose": "bun tests/compare.ts --verbose",
    "test:perf:compare:md": "bun tests/compare.ts --markdown",
    "lint": "bunx eslint src/ tests/",
    "lint:fix": "bunx eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "bunx prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "bunx prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "update-chain-specs": "bash scripts/update-chain-specs.sh",
    "update-metadata": "bash scripts/update-metadata.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.5",
    "@types/qrcode": "^1.5.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "simple-statistics": "^7.8.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-wasm": "^3.5.0"
  },
  "dependencies": {
    "@chainsafe/libp2p-noise": "^17.0.0",
    "@chainsafe/libp2p-yamux": "^8.0.1",
    "@ensdomains/content-hash": "^3.0.0",
    "@helia/block-brokers": "^5.1.2",
    "@helia/routers": "^5.0.3",
    "@helia/unixfs": "^7.0.4",
    "@ipld/car": "^5.4.2",
    "@ipld/dag-pb": "^4.1.5",
    "@libp2p/identify": "^4.0.12",
    "@libp2p/ping": "^3.0.12",
    "@libp2p/websockets": "^10.1.5",
    "@multiformats/blake2": "^2.0.2",
    "@multiformats/multiaddr": "^13.0.1",
    "@noble/hashes": "^2.0.1",
    "@novasamatech/host-container": "^0.6.6-1",
    "@novasamatech/host-papp": "^0.6.6-1",
    "@novasamatech/statement-store": "^0.6.6-1",
    "@novasamatech/storage-adapter": "^0.6.6-1",
    "@polkadot-api/descriptors": "file:.papi/descriptors",
    "@polkadot-api/json-rpc-provider": "^0.0.4",
    "@polkadot-api/json-rpc-provider-proxy": "^0.2.8",
    "@polkadot-api/metadata-builders": "^0.13.9",
    "@polkadot-api/substrate-bindings": "^0.17.0",
    "@polkadot-api/utils": "^0.2.0",
    "@scure/sr25519": "^1.0.0",
    "@sentry/browser": "^10.42.0",
    "helia": "^6.0.20",
    "ipfs-unixfs": "^12.0.0",
    "multiformats": "^13.4.2",
    "neverthrow": "^8.2.0",
    "polkadot-api": "^1.23.3",
    "qrcode": "^1.5.4",
    "scale-ts": "^1.6.1",
    "smoldot": "^2.0.40"
  },
  "packageManager": "bun@1.3.6",
  "trustedDependencies": [
    "node-datachannel"
  ]
}
