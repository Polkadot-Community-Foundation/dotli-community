{
  "name": "dotli",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/dotli.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "preview": "turbo run build && bun scripts/preview-server.ts",
    "preview:debug": "VITE_APP_DEBUG=true bun preview",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "find . -type d \\( -name node_modules -o -name dist \\) -prune -exec rm -rf {} +"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "smoldot": "^3.1.4"
  },
  "overrides": {
    "smoldot": "3.1.4"
  },
  "patchedDependencies": {
    "@novasamatech/host-papp@0.8.5": "patches/@novasamatech%2Fhost-papp@0.8.5.patch"
  }
}
