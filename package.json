{
  "name": "dotli",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paritytech/dotli.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "build:prod": "turbo run build:prod",
    "preview": "turbo run build && bun scripts/preview-server.ts",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "^2.9.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
