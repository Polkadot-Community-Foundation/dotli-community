# Copy this file to deploy.env (gitignored) and fill in your deploy targets.
# deploy.env is included by the Makefile, so use Make assignment syntax.
#
# REMOTE_PRD is the production box. REMOTE_STG is the shared staging/dev box
# used by every non-prod env. Alternatively, pass REMOTE=user@host on the
# command line to override per run without a deploy.env file.

REMOTE_PRD := ubuntu@your.production.host
REMOTE_STG := ubuntu@your.staging.host

# REMOTE_SUMMIT is the dedicated public box for ENV=summit. With SSH access
# tunneled through GCP IAP, point it at an ssh-config Host alias instead of
# user@ip (see the infra repo README).
REMOTE_SUMMIT := pcf-summit-dotli
