{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["DEV", "BASE_URL", "VITE_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["build"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "tauri": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "tauri:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "tauri:build": {
      "dependsOn": ["^build"],
      "outputs": ["src-tauri/target/**"]
    }
  }
}
