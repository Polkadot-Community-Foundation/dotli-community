# westendli.dev NGINX Configuration
#
# Three-build architecture:
#   host.westendli.dev    → Shared protocol host (smoldot, shared chain cache)
#   *.westendli.dev       → Host build (topbar, routing shell, bridge)
#   *.app.westendli.dev   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: westendli.dev (separate cert for *.app.westendli.dev).

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name westendli.dev *.westendli.dev host.westendli.dev *.app.westendli.dev;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: westendli.dev — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name westendli.dev;

    ssl_certificate     /etc/letsencrypt/live/westendli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westendli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/westendlidev/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location = /__preview {
        set $csp_ancestors "revx.dev stg.revx.dev http://localhost:*";
        include /etc/nginx/snippets/dotli-headers-iframeable.conf;
        try_files /index.html =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.westendli.dev — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.westendli.dev;

    ssl_certificate     /etc/letsencrypt/live/app.westendli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.westendli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "westendli.dev *.westendli.dev *.app.westendli.dev";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendlidev/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.westendli.dev — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.westendli.dev;

    ssl_certificate     /etc/letsencrypt/live/westendli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westendli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "westendli.dev *.westendli.dev *.app.westendli.dev revx.dev stg.revx.dev http://localhost:*";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendlidev/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.westendli.dev — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.westendli.dev;

    ssl_certificate     /etc/letsencrypt/live/westendli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westendli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendlidev/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
