# dotli.dev NGINX Configuration
#
# Three-build architecture:
#   host.dotli.dev    → Shared protocol host (smoldot, shared chain cache)
#   *.dotli.dev       → Host build (topbar, routing shell, bridge)
#   *.app.dotli.dev   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: dotli.dev (separate cert for *.app.dotli.dev).

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name dotli.dev *.dotli.dev host.dotli.dev *.app.dotli.dev;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: dotli.dev — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name dotli.dev;

    ssl_certificate     /etc/letsencrypt/live/dotli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dotli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/dotlidev/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location = /__preview {
        set $csp_ancestors "revx.dev stg.revx.dev http://localhost:*";
        include /etc/nginx/snippets/dotli-headers-iframeable.conf;
        try_files /index.html =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.dotli.dev — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.dotli.dev;

    ssl_certificate     /etc/letsencrypt/live/app.dotli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.dotli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "dotli.dev *.dotli.dev *.app.dotli.dev";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/dotlidev/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.dotli.dev — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.dotli.dev;

    ssl_certificate     /etc/letsencrypt/live/dotli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dotli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "dotli.dev *.dotli.dev *.app.dotli.dev revx.dev stg.revx.dev http://localhost:*";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/dotlidev/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.dotli.dev — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.dotli.dev;

    ssl_certificate     /etc/letsencrypt/live/dotli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dotli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/dotlidev/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
