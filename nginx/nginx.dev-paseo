# paseoli.dev NGINX Configuration
#
# Three-build architecture:
#   host.paseoli.dev    → Shared protocol host (smoldot, shared chain cache)
#   *.paseoli.dev       → Host build (topbar, routing shell, bridge)
#   *.app.paseoli.dev   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: paseoli.dev (separate cert for *.app.paseoli.dev).

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name paseoli.dev *.paseoli.dev host.paseoli.dev *.app.paseoli.dev;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: paseoli.dev — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name paseoli.dev;

    ssl_certificate     /etc/letsencrypt/live/paseoli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseoli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/paseolidev/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location = /__preview {
        set $csp_ancestors "revx.dev stg.revx.dev http://localhost:*";
        include /etc/nginx/snippets/dotli-headers-iframeable.conf;
        try_files /index.html =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.paseoli.dev — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.paseoli.dev;

    ssl_certificate     /etc/letsencrypt/live/paseoli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseoli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "paseoli.dev *.paseoli.dev *.app.paseoli.dev";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseolidev/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.paseoli.dev — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.paseoli.dev;

    ssl_certificate     /etc/letsencrypt/live/paseoli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseoli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "paseoli.dev *.paseoli.dev *.app.paseoli.dev revx.dev stg.revx.dev http://localhost:*";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseolidev/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.paseoli.dev — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.paseoli.dev;

    ssl_certificate     /etc/letsencrypt/live/paseoli.dev/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseoli.dev/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseolidev/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
