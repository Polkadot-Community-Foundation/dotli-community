# testnet.li NGINX Configuration
#
# Three-build architecture:
#   host.testnet.li    → Shared protocol host (smoldot, shared chain cache)
#   *.testnet.li       → Host build (topbar, routing shell, bridge)
#   *.app.testnet.li   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: testnet.li (separate cert for *.app.testnet.li).
#
# NOTE: web roots below point at /var/www/testnetli/* — verify this
# matches the deploy path on the testnet.li host before reloading.

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name testnet.li *.testnet.li host.testnet.li *.app.testnet.li;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: testnet.li — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name testnet.li;

    ssl_certificate     /etc/letsencrypt/live/testnet.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/testnet.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/testnetli/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location = /__preview {
        set $csp_ancestors "revx.dev stg.revx.dev http://localhost:*";
        include /etc/nginx/snippets/dotli-headers-iframeable.conf;
        try_files /index.html =404;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.testnet.li — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.testnet.li;

    ssl_certificate     /etc/letsencrypt/live/testnet.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/testnet.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "testnet.li *.testnet.li *.app.testnet.li";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/testnetli/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.testnet.li — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.testnet.li;

    ssl_certificate     /etc/letsencrypt/live/testnet.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/testnet.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "testnet.li *.testnet.li *.app.testnet.li revx.dev stg.revx.dev http://localhost:*";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/testnetli/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.testnet.li — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.testnet.li;

    ssl_certificate     /etc/letsencrypt/live/testnet.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/testnet.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/testnetli/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
