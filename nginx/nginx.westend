# westend.li NGINX Configuration
#
# Three-build architecture:
#   host.westend.li    → Shared protocol host (smoldot, shared chain cache)
#   *.westend.li       → Host build (topbar, routing shell, bridge)
#   *.app.westend.li   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: westend.li (separate cert for *.app.westend.li).
#
# NOTE: web roots below point at /var/www/westendli/* — verify this
# matches the deploy path on the westend.li host before reloading.

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name westend.li *.westend.li host.westend.li *.app.westend.li;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: westend.li — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name westend.li;

    ssl_certificate     /etc/letsencrypt/live/westend.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westend.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/westendli/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.westend.li — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.westend.li;

    ssl_certificate     /etc/letsencrypt/live/app.westend.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/app.westend.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "westend.li *.westend.li *.app.westend.li";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendli/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.westend.li — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.westend.li;

    ssl_certificate     /etc/letsencrypt/live/westend.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westend.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "westend.li *.westend.li *.app.westend.li";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendli/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.westend.li — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.westend.li;

    ssl_certificate     /etc/letsencrypt/live/westend.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/westend.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/westendli/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
