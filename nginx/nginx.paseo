# paseo.li NGINX Configuration
#
# Three-build architecture:
#   host.paseo.li    → Shared protocol host (smoldot, shared chain cache)
#   *.paseo.li       → Host build (topbar, routing shell, bridge)
#   *.app.paseo.li   → App build  (CID from subdomain, P2P fetch, render)
#
# SSL cert covers: paseo.li (single multi-SAN cert).
#
# NOTE: web roots below point at /var/www/paseoli/* — verify this matches
# the deploy path on the paseo.li host before reloading.

# ────────────────────────────────────────────────────────────
# HTTP → HTTPS redirect
# ────────────────────────────────────────────────────────────

server {
    listen 80;
    server_name paseo.li *.paseo.li host.paseo.li *.app.paseo.li;
    return 301 https://$host$request_uri;
}

# ────────────────────────────────────────────────────────────
# Root domain: paseo.li — Landing page
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name paseo.li;

    ssl_certificate     /etc/letsencrypt/live/paseo.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseo.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    root /var/www/paseoli/host;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# App build: *.app.paseo.li — CID content fetching & rendering
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.app.paseo.li;

    ssl_certificate     /etc/letsencrypt/live/paseo.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseo.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "paseo.li *.paseo.li *.app.paseo.li";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseoli/app;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;
    include /etc/nginx/snippets/dotli-sw-app.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Shared protocol build: host.paseo.li — smoldot / shared cache origin
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name host.paseo.li;

    ssl_certificate     /etc/letsencrypt/live/paseo.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseo.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    set $csp_ancestors "paseo.li *.paseo.li *.app.paseo.li";
    include /etc/nginx/snippets/dotli-headers-iframeable.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseoli/protocol;
    index index.html;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-iframeable.conf;

    location / {
        try_files $uri /index.html;
    }
}

# ────────────────────────────────────────────────────────────
# Host build: *.paseo.li — Shell with topbar, routing, bridge
# ────────────────────────────────────────────────────────────

server {
    listen 443 ssl http2;
    server_name *.paseo.li;

    ssl_certificate     /etc/letsencrypt/live/paseo.li/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/paseo.li/privkey.pem;
    include /etc/nginx/snippets/dotli-ssl.conf;

    include /etc/nginx/snippets/dotli-headers-host.conf;
    include /etc/nginx/snippets/dotli-precompressed.conf;

    root /var/www/paseoli/host;

    include /etc/nginx/snippets/sentry-tunnel.conf;
    include /etc/nginx/snippets/dotli-assets-host.conf;
    include /etc/nginx/snippets/dotli-sw-host.conf;

    location / {
        try_files $uri /index.html;
    }
}
