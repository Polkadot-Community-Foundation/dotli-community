# App URL - used for asset base path (e.g. https://paseo.li, http://localhost:5173)
VITE_APP_URL=

# Destination for the "Get Polkadot Desktop" banner shown on non-mobile
# user agents. When unset, falls back to
# https://polkadot.com/get-started/polkadot-for-desktop.
VITE_DESKTOP_DOWNLOAD_URL=

# Required. Comma-separated networks this build offers in the Settings
# selector. Each value must match a `NetworkName` in
# `packages/config/src/network.ts`.
VITE_NETWORKS=

# Set to "true" to enable verbose `log.debug` output (see
# packages/shared/src/log.ts) and auto-mount the TrUAPI debug panel
# (collapsed) on page load. Users can also opt in at runtime in any
# build via the Settings "Open in debug mode" button or `?debug=true`.
VITE_APP_DEBUG=

# Set to "true" to send spans/measurements/counters to Sentry and keep the
# analytics SDKs in the bundle. Unset/empty (the default) makes all metric
# calls no-ops and strips the Sentry/metrics modules from the build.
VITE_METRICS=

# Set (to any non-empty value) to activate the sandbox-checker tooling at
# build time (see packages/sandbox-checker). Leave unset for normal builds.
VITE_SANDBOX_CHECKER=

# Set to "true" to use the smoldot light client for the statement store
# chain. Defaults to false; enable in development for testing and feedback.
VITE_SS_USE_SMOLDOT=

# Optional relay chain spec override for the statement store people chain.
# Chain-spec file name without `.json`, e.g. "westend-local". When unset,
# the default Paseo relay chain is reused.
VITE_SS_RELAY_CHAIN=

# Commit SHA stamped into the build.
VITE_COMMIT_SHA=

# Sentry DSN for browser error reporting. When unset, Sentry is a no-op.
VITE_SENTRY_DSN=

# Sentry sourcemap upload token.
SENTRY_AUTH_TOKEN=

# E2E (apps/host/e2e) — pairing tests against mission-control signer bot.
# Service-account token issued by mission-control with `signer:provision`.
SIGNER_BOT_SVC_TOKEN=
SIGNER_BOT_BASE_URL=https://signing-bot-dev.novasama-tech.org/
# MUST match the host's `defaultNetwork()` in `packages/config/src/network.ts`.
# Drift produces a silent "pair OK, user-badge never appears" failure: the
# bot attests on one chain, the host listens on another, and the chain-side
# handshake never reaches the host.
SIGNER_BOT_NETWORK=paseo-next-v2
